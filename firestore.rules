rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: each person manages their own profile; only admins can change roles
    // or read other people's profiles.
    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId &&
        request.resource.data.role == 'user';
      allow update: if signedIn() && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // Products: readable by any signed-in shopper, editable only by admins.
    match /products/{productId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Store-wide settings (SINPE info, policies, categories): admin-managed.
    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Carts: strictly private to their owner.
    match /carts/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Orders: a shopper can create/read their own; only admins can update
    // status (payment verification, shipping) or read everyone's orders.
    match /orders/{orderId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Newsletter signups: anyone signed in can subscribe; only admins can
    // read the list.
    match /newsletterSubscribers/{email} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
